{
  "name": "@kafil/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p ${API_PORT:-3001}",
    "build": "next build",
    "start": "next start -p ${API_PORT:-3001}",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev && psql \"$DATABASE_URL\" -f prisma/sql/001_partial_indexes.sql",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@kafil/core": "*",
    "@prisma/client": "^5.22.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
