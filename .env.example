# Copy to .env.local in apps/api before first run.
# Provider keys are stubbed locally so the app boots offline (P2).

# --- Database ---
DATABASE_URL="postgresql://kafil:kafil_local@localhost:5433/kafil?schema=public"

# --- API server ---
API_PORT=3001
NODE_ENV=development

# --- Provider stubs (real values come from secret manager in prod) ---
SMS_PROVIDER=console        # console | twilio
WHATSAPP_PROVIDER=console   # console | twilio_whatsapp
STORAGE_PROVIDER=local      # local | s3
PAYMENT_PROVIDER=console    # console | jazzcash | easypaisa

# --- Provisional rates (§6.1; mirrored in DB `settings` for prod, env for dev) ---
COMMISSION_ESCROW_PCT=5
COMMISSION_ESCROW_MIN_MINOR=5000
COMMISSION_ESCROW_CAP_MINOR=2000000
CASH_FEATURED_POST_PKR=150
CASH_APPLICANT_UNLOCK_PKR=50
VERIFICATION_SHOP_TIER_MONTHLY_PKR=500
VERIFICATION_WORKER_PRO_MONTHLY_PKR=200
GUARANTEE_FEE_PCT=2
REFERRAL_REWARD_MINOR=30000

# --- Hold thresholds (§6.2 merged B4+M4 rule) ---
HOLD_LOW_RISK_MINUTES=0
HOLD_MEDIUM_RISK_MINUTES=1440
HOLD_HIGH_RISK_MINUTES=2880

# --- §28.B ops capacity (drives admin dashboard ops-load forecast) ---
OPS_REVIEW_CAPACITY_MINUTES_PER_WEEK=600
